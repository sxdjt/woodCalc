{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wood Shop Calc",
  "version": "0.1.0",
  "identifier": "com.sxdjt.woodcalc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Wood Shop Calc",
        "width": 520,
        "height": 900,
        "minWidth": 400,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
